Index: linux-7.0/drivers/gpu/drm/drm_edid.c
===================================================================
--- linux-7.0.orig/drivers/gpu/drm/drm_edid.c
+++ linux-7.0/drivers/gpu/drm/drm_edid.c
@@ -3510,6 +3510,7 @@ static void drm_mode_do_interlace_quirk(struct drm_display_mode *mode,
 {
 	int i;
+	bool doubled = false;
 	static const struct {
 		int w, h;
 	} cea_interlaced[] = {
@@ -3525,14 +3526,35 @@ static void drm_mode_do_interlace_quirk(struct drm_display_mode *mode,
 	for (i = 0; i < ARRAY_SIZE(cea_interlaced); i++) {
 		if ((mode->hdisplay == cea_interlaced[i].w) &&
 		    (mode->vdisplay == cea_interlaced[i].h / 2)) {
 			mode->vdisplay *= 2;
 			mode->vsync_start *= 2;
 			mode->vsync_end *= 2;
 			mode->vtotal *= 2;
 			mode->vtotal |= 1;
+			doubled = true;
+			break;
 		}
 	}
 
+	/*
+	 * EXPERIMENTAL CRT / custom EDID interlace expansion:
+	 *
+	 * The upstream quirk above only expands known CEA interlaced
+	 * detailed timings. High-resolution PC CRT interlaced DTDs, such
+	 * as 1600x1200i or 1792x1344i, are otherwise exposed through DRM
+	 * as their field height, e.g. 1600x600 + INTERLACE.
+	 *
+	 * For this custom-EDID CRT workflow, expand non-CEA interlaced
+	 * detailed timings the same way so userspace sees the full-frame
+	 * geometry.
+	 */
+	if (!doubled) {
+		mode->vdisplay *= 2;
+		mode->vsync_start *= 2;
+		mode->vsync_end *= 2;
+		mode->vtotal *= 2;
+		mode->vtotal |= 1;
+	}
+
 	mode->flags |= DRM_MODE_FLAG_INTERLACE;
 }
