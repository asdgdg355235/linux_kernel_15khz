Index: linux-7.0/drivers/gpu/drm/amd/display/dc/dio/dcn10/dcn10_stream_encoder.c
===================================================================
--- linux-7.0.orig/drivers/gpu/drm/amd/display/dc/dio/dcn10/dcn10_stream_encoder.c
+++ linux-7.0/drivers/gpu/drm/amd/display/dc/dio/dcn10/dcn10_stream_encoder.c
@@ -263,6 +263,10 @@ void enc1_stream_encoder_dp_set_stream_a
 	struct dc_crtc_timing hw_crtc_timing = *crtc_timing;
 
 	if (hw_crtc_timing.flags.INTERLACE) {
+		/*DCN needs even vertical fields*/
+		hw_crtc_timing.v_total = (hw_crtc_timing.v_total + 1) & ~1;
+		hw_crtc_timing.v_front_porch = (hw_crtc_timing.v_front_porch + 1) & ~1;
+		hw_crtc_timing.v_sync_width = (hw_crtc_timing.v_sync_width + 1) & ~1;
 		/*the input timing is in VESA spec format with Interlace flag =1*/
 		hw_crtc_timing.v_total /= 2;
 		hw_crtc_timing.v_border_top /= 2;
